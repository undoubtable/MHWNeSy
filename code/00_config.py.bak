# -*- coding: utf-8 -*-
"""
Shared paths for the MHW-NeurRL pipeline.

All generated outputs are saved under:
    /ybz/ybz/2026/MHWNeurRL/outputs
"""

from pathlib import Path

ROOT = Path("/ybz/ybz/2026/MHWNeurRL")

# Raw data stays here.
RAW_NC = ROOT / "data" / "oisst_scs_1982_2023.nc"

# Unified output root.
OUTPUT_DIR = ROOT / "outputs"

# Step-wise output folders.
LABEL_DIR = OUTPUT_DIR / "01_mhw_labels"
FIGURE_DIR = OUTPUT_DIR / "02_label_visualization"
FORECAST_DIR = OUTPUT_DIR / "03_forecast_dataset_h10_l5"
UNET_RUN_DIR = OUTPUT_DIR / "04_unet_baseline_h10_l5"
EVENT_DIR = OUTPUT_DIR / "06_neurrl_event_dataset_h10_l5"

# Main files.
LABEL_NC = LABEL_DIR / "mhw_labels_strict_hobday_1982_2023.nc"
UNET_BEST = UNET_RUN_DIR / "best_model.pt"

for d in [
    OUTPUT_DIR,
    LABEL_DIR,
    FIGURE_DIR,
    FORECAST_DIR,
    UNET_RUN_DIR,
    EVENT_DIR,
]:
    d.mkdir(parents=True, exist_ok=True)
